import pandas as pd
import numpy as np
import random
from datetime import datetime, timedelta

print("--- STEP 1: STARTING DATA INGESTION PIPELINE ---")

# 1. Base Data Setup
records = 1000  
cities = ['Mumbai', 'Delhi', 'Bangalore', 'Hyderabad', 'Pune']
products = ['Headphones', 'Smartwatch', 'Laptop', 'Keyboard', 'Mouse']

data = {
    'Order_ID': [f'ORD{1000 + i}' for i in range(records)],
    'Date': [(datetime(2026, 1, 1) + timedelta(days=random.randint(0, 180))).strftime('%Y-%m-%d') for i in range(records)],
    'City': [random.choice(cities) for i in range(records)],
    'Product': [random.choice(products) for i in range(records)],
    'Sales': np.random.normal(loc=5000, scale=1500, size=records).round(2)
}

df = pd.DataFrame(data)

# Injecting Nulls and Outliers for interview showcase
df.loc[df.sample(frac=0.05).index, 'Sales'] = np.nan 
df.loc[df.sample(n=5).index, 'Sales'] = 500000.00  

# Raw file save karna
df.to_csv('raw_sales_data.csv', index=False)
print("✔ Raw Data Successfully Generated with Nulls & Outliers!")

print("\n--- STEP 2: STARTING DATA CLEANING PROCESS ---")

# Raw data ko read karna
df_raw = pd.read_csv('raw_sales_data.csv')

# 1. Total Missing Values check karna (Aapka bataya hua logic)
print("Total Null Values before cleaning:")
print(df_raw.isnull().sum())  

# 2. Sales column ke Null values ko 0 se replace karna (Aapka bataya hua logic)
df_raw['Sales'] = df_raw['Sales'].fillna(0)  

# 3. Clean data ko save karna jo hum SQL me bhejenge
df_raw.to_csv('clean_sales_data.csv', index=False)
print("✔ Data Cleaned and Saved as 'clean_sales_data.csv'!")